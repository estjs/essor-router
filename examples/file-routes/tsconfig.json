{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "preserve",
    "jsxImportSource": "essor",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "plugins": [
      {
        "name": "essor-router-ts-plugin"
      }
    ],
    "paths": {
      "essor-router": [
        "./node_modules/essor-router"
      ]
    },
    "types": [
      "vite/client"
    ],
    "strict": true
  },
  "include": [
    "src"
  ]
}
