{
  "name": "essor-router-monorepo",
  "version": "0.0.17-beta.5",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "dev": "pnpm --filter essor-router run dev",
    "docs:dev": "athen dev docs",
    "docs:build": "athen build docs",
    "docs:preview": "athen preview docs",
    "lint": "eslint ./ --cache",
    "lint:fix": "eslint ./ --fix --cache",
    "typecheck": "pnpm -r --filter './packages/*' run typecheck",
    "typecheck:examples": "pnpm run build && pnpm -r --filter './examples/*' run typecheck",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run",
    "test:unplugin": "vitest run --project unplugin",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run typecheck:examples && pnpm run test:unit",
    "check:ci": "pnpm run check",
    "changelog": "tsx scripts/changelog.ts",
    "prerelease": "pnpm run check:ci",
    "release": "pnpm run changelog && pnpm run prerelease && bumpp package.json packages/*/package.json --no-git-checks --commit --push --tag"
  },
  "devDependencies": {
    "@estjs/eslint-config": "^2.3.0",
    "@playwright/test": "^1.60.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "4.1.8",
    "athen": "^0.0.8-beta.9",
    "bumpp": "^11.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.1",
    "essor": "^0.0.17-beta.2",
    "faked-promise": "^2.2.2",
    "glob": "^13.0.6",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "picocolors": "^1.1.1",
    "pnpm": "^11.5.3",
    "prettier": "^3.8.4",
    "simple-git-hooks": "^2.13.1",
    "standard-changelog": "6.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zx": "^8.8.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged --concurrent false",
    "commit-msg": "pnpm exec tsx ./scripts/verify-commit.ts $1"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx}": "eslint --cache --fix"
  }
}
