{
  "name": "unplugin-essor-router",
  "version": "0.0.17-beta.5",
  "description": "",
  "type": "module",
  "keywords": [],
  "license": "MIT",
  "homepage": "https://github.com/estjs/essor-router#readme",
  "bugs": "https://github.com/estjs/essor-router/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/estjs/essor-router.git"
  },
  "author": "jiangxd <jiangxd2016@gmail.com>",
  "funding": "https://github.com/sponsors/estjs",
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "require": "./dist/vite.cjs",
      "import": "./dist/vite.mjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "require": "./dist/webpack.cjs",
      "import": "./dist/webpack.mjs"
    },
    "./rollup": {
      "types": "./dist/rollup.d.ts",
      "require": "./dist/rollup.cjs",
      "import": "./dist/rollup.mjs"
    },
    "./rolldown": {
      "types": "./dist/rolldown.d.ts",
      "require": "./dist/rolldown.cjs",
      "import": "./dist/rolldown.mjs"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.ts",
      "require": "./dist/esbuild.cjs",
      "import": "./dist/esbuild.mjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "require": "./dist/config.cjs",
      "import": "./dist/config.mjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "require": "./dist/types.cjs",
      "import": "./dist/types.mjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup && cross-env NODE_ENV=production tsup --clean=false --treeshake --sourcemap=false",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit -p ./tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@babel/generator": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@estjs/shared": "^0.0.16",
    "ast-walker-scope": "^0.9.0",
    "chokidar": "^5.0.0",
    "json5": "^2.2.3",
    "local-pkg": "^1.2.1",
    "magic-string": "^0.30.21",
    "mlly": "^1.8.2",
    "pathe": "^2.0.3",
    "picomatch": "^4.0.4",
    "tinyglobby": "^0.2.16",
    "unplugin": "^3.0.0",
    "unplugin-utils": "^0.3.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@babel/types": "^7.29.7",
    "vite": "^8.0.14"
  }
}
