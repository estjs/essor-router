"
const __route_0 = normalizeRouteRecord({
  name: '/users/[id]/posts/[postId]',
  path: new MatcherPatternPathDynamic(
    /^\\/users\\/([^/]+?)\\/posts\\/([^/]+?)$/i,
    {
      id: [/* no parser */],
      postId: [/* no parser */],
    },
    ["users",1,"posts",1],
    /* trailingSlash */
  ),
  components: {
    'default': () => import('/src/pages/users/[id]/posts/[postId].tsx')
  },
})

export const resolver = createFixedResolver([
  __route_0,  // /users/:id/posts/:postId
])
"
`;

