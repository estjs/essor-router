exports[`generateRouteResolver snapshot > generates stable resolver for standard routes 1`] = `
"
const __route_0 = normalizeRouteRecord({
  name: '/',
  path: new MatcherPatternPathStatic('/'),
  components: {
    'default': () => import('/src/pages/index.tsx')
  },
})

const __route_1 = normalizeRouteRecord({
  name: '/[...all]',
  path: new MatcherPatternPathDynamic(
    /^\\/(.*)$/i,
    {
      all: [/* no parser */],
    },
    [0],
    null,
  ),
  components: {
    'default': () => import('/src/pages/[...all].tsx')
  },
})

const __route_2 = normalizeRouteRecord({
  name: '/about',
  path: new MatcherPatternPathStatic('/about'),
  components: {
    'default': () => import('/src/pages/about.tsx')
  },
})

const __route_3 = normalizeRouteRecord({
  name: '/users/[id]',
  path: new MatcherPatternPathDynamic(
    /^\\/users\\/([^/]+?)$/i,
    {
      id: [/* no parser */],
    },
    ["users",1],
    /* trailingSlash */
  ),
  components: {
    'default': () => import('/src/pages/users/[id].tsx')
  },
})
const __route_4 = normalizeRouteRecord({
  name: '/users/[id]/posts',
  path: new MatcherPatternPathDynamic(
    /^\\/users\\/([^/]+?)\\/posts$/i,
    {
      id: [/* no parser */],
    },
    ["users",1,"posts"],
    /* trailingSlash */
  ),
  components: {
    'default': () => import('/src/pages/users/[id]/posts.tsx')
  },
  parent: __route_3,
})

export const resolver = createFixedResolver([
  __route_4,  // /users/:id/posts
  __route_3,  // /users/:id
  __route_2,  // /about
  __route_0,  // /
  __route_1,  // /:all(.*)
])
"
`;

