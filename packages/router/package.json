        "./dist/index.d.ts"
      ]
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup && cross-env NODE_ENV=production tsup --clean=false --treeshake --sourcemap=false",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit -p ./tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "essor": "^0.0.16-beta.1"
  },
  "dependencies": {
    "@estjs/shared": "^0.0.16-beta.1"
